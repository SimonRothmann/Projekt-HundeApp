# Vorlage für die VPS-.env (siehe deploy/README.md) - Datei mit echten
# Werten NIE committen (.env ist in .gitignore).

# --- Domains (vorher per DNS A-Record auf die VPS-IP zeigen lassen) ---
PROD_DOMAIN=dogity.example.com
PROD_API_DOMAIN=api.dogity.example.com
TEST_DOMAIN=test.dogity.example.com
TEST_API_DOMAIN=api-test.dogity.example.com

# E-Mail für Let's-Encrypt-Benachrichtigungen (Caddy)
ACME_EMAIL=admin@example.com

# --- Datenbank ---
# Mit z.B. `openssl rand -base64 32` erzeugen, je Wert unterschiedlich.
POSTGRES_SUPERUSER_PASSWORD=
DOGITY_PROD_DB_PASSWORD=
DOGITY_TEST_DB_PASSWORD=

# --- JWT-Signaturschlüssel ---
# Mit `openssl rand -base64 48` erzeugen - Prod/Test bewusst unterschiedlich,
# damit ein Token aus Test niemals in Prod gültig ist (und umgekehrt).
PROD_JWT_SECRET=
TEST_JWT_SECRET=

# --- Admin-Bootstrap (optional) ---
# E-Mail-Adresse eines bereits registrierten Nutzers, der beim nächsten
# Start die ADMIN-Rolle bekommt (siehe AdminBootstrapper.cs). Leer lassen,
# um das zu überspringen.
PROD_ADMIN_EMAIL=
TEST_ADMIN_EMAIL=
